# ============================================
# SSO System - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in actual values
# DO NOT commit .env with real credentials

# ============================================
# SERVER CONFIG
# ============================================
PORT=5000
NODE_ENV=development
# NODE_ENV=production

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_DB_NAME=sso_system

# ============================================
# JWT & AUTHENTICATION
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRE=30d

# ============================================
# CORS & FRONTEND DEPLOYMENT
# ============================================
# Client URL - single frontend domain
CLIENT_URL=http://localhost:5173
# For multiple origins, comma-separated (no spaces or trimmed)
ALLOWED_ORIGINS=https://yourdomain.amplifyapp.com,https://yourdomain.com

# ============================================
# IME FOREX INTEGRATION - SOAP API
# ============================================
IME_SOAP_BASE_URL=https://imepay.com.np/api/secure/ime-pay-soap/
IME_ACCESS_CODE=your-ime-access-code
IME_USERNAME=your-ime-username
IME_PASSWORD=your-ime-password
IME_PARTNER_BRANCH_ID=your-branch-id
IME_AGENT_SESSION_ID=your-agent-session-id-or-leave-blank

# ============================================
# EMAIL CONFIGURATION (Nodemailer)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# OAUTH / THIRD-PARTY SERVICES
# ============================================
# Google OAuth (if used for admin)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# FEATURE FLAGS & ADMIN SETTINGS
# ============================================
ENABLE_IME_PAYMENT=true
ENABLE_PRABHU_PAYMENT=true
ENABLE_KYC_VERIFICATION=true
ENABLE_BIOMETRIC_AUTH=true
ENABLE_2FA_SMS=true
ENABLE_2FA_EMAIL=true

# ============================================
# EXTERNAL SERVICE INTEGRATIONS
# ============================================
# Prabhu SMS Gateway (if used)
PRABHU_API_KEY=your-prabhu-api-key
PRABHU_API_SECRET=your-prabhu-api-secret

# WhatsApp Integration (if used)
WHATSAPP_BUSINESS_PHONE_ID=your-phone-id
WHATSAPP_API_TOKEN=your-api-token

# ============================================
# LOGGING & MONITORING
# ============================================
LOG_LEVEL=info
# LOG_LEVEL=debug (for development)

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# FILE UPLOADS
# ============================================
MAX_UPLOAD_SIZE=5242880
ALLOWED_UPLOAD_EXTENSIONS=pdf,jpg,jpeg,png,doc,docx

# ============================================
# PAYMENT PROCESSING
# ============================================
# Stripe (if integrated)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ============================================
# DEPLOYMENT SPECIFIC
# ============================================
# For Vercel: Auto-detected
# For AWS: Set accordingly
ENVIRONMENT=development
# ENVIRONMENT=production
# ENVIRONMENT=staging
